# Sovereign Dominion — Demo Backend Environment
# Copy to .env and fill in your API keys:
#   cp .env.example .env

# ─── NVIDIA NIM ──────────────────────────────────────────────────────────────
# Required for live Nemotron-4-340B council and Hermes-3-405B orchestration.
# Get your key at: https://build.nvidia.com/
# Without this key, the server runs in mock mode (fully functional for demos).
NVIDIA_API_KEY=

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Required for live PaymentIntent creation and confirmation.
# Use a TEST key (sk_test_...) — server auto-confirms with pm_card_visa.
# Get your key at: https://dashboard.stripe.com/test/apikeys
# Without this key, payment results are mocked (PASS shows "succeeded (mock)").
STRIPE_SECRET_KEY=

# ─── Server ──────────────────────────────────────────────────────────────────
# Optional: override the default port (3001)
# PORT=3001

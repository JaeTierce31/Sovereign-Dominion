# Stripe — get test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# NVIDIA NIM — get from https://build.nvidia.com (free tier sufficient)
# Powers Chromatic Council (Nemotron-4-340B) and Hermes orchestration
NVIDIA_API_KEY=nvapi-...

# Optional: separate key for Hermes if using a different NIM project
# HERMES_API_KEY=nvapi-...

# Server port (default: 3001)
# PORT=3001
